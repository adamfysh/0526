---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Narrows — Trade Risk Intelligence"
  description="Trade risk intelligence. The news tells you what happened. Narrows tells you what it costs."
>

<style>
/* ─────────────────────────────────────────
   HERO
───────────────────────────────────────── */
.hero {
  padding: 136px var(--s4) var(--s6);
  max-width: var(--max-w);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 80px;
  align-items: center;
}
.hero-kicker {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  margin-bottom: var(--s3);
}
.hero-kicker-line { width: 32px; height: 1px; background: var(--gold); flex-shrink: 0; }
.hero-headline {
  font-size: clamp(36px, 4.5vw, 56px);
  font-weight: 700;
  line-height: 1.08;
  color: var(--navy);
  margin-bottom: var(--s3);
  letter-spacing: -0.025em;
}
.hero-headline em { font-style: italic; font-weight: 400; color: var(--blue-light); }
.hero-tagline {
  font-size: 18px;
  font-weight: 300;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--s2);
  max-width: 480px;
}
.hero-tagline strong { color: var(--text-primary); font-weight: 600; }
.hero-sub {
  font-size: 15px;
  color: var(--text-tertiary);
  max-width: 460px;
  line-height: 1.7;
  margin-bottom: var(--s4);
  font-weight: 300;
}
.hero-actions { display: flex; align-items: center; gap: var(--s3); flex-wrap: wrap; }

/* Simulator preview card */
.sim-card {
  background: var(--navy);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(10,37,64,0.2), 0 4px 16px rgba(10,37,64,0.1);
}
.sim-card-topbar {
  background: rgba(255,255,255,0.05);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.sim-card-dots { display: flex; gap: 5px; }
.sim-card-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.12); }
.sim-card-url { font-size: 10px; color: rgba(255,255,255,0.2); letter-spacing: 0.04em; font-family: 'SF Mono','Fira Code',monospace; }
.sim-card-header { padding: 16px 20px; border-bottom: 3px solid var(--gold); }
.sim-card-eyebrow { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 6px; }
.sim-card-scenario { font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.5; }
.sim-card-scenario strong { color: var(--gold); font-weight: 600; }
.sim-row { display: flex; align-items: center; justify-content: space-between; padding: 11px 20px; border-bottom: 1px solid rgba(255,255,255,0.05); }
.sim-row:last-child { border-bottom: none; }
.sim-row-label { font-size: 11px; color: rgba(255,255,255,0.35); font-weight: 400; }
.sim-row-value { font-size: 20px; font-weight: 700; color: var(--white); letter-spacing: -0.01em; }
.sim-row-value .unit { font-size: 11px; font-weight: 400; color: rgba(255,255,255,0.25); margin-left: 3px; }
.sim-card-footer { padding: 10px 20px; background: rgba(255,255,255,0.03); border-top: 1px solid rgba(255,255,255,0.05); font-size: 10px; color: rgba(255,255,255,0.18); letter-spacing: 0.04em; }

/* ─────────────────────────────────────────
   TRUST BAR
───────────────────────────────────────── */
.trust-bar { border-top: var(--rule-light); border-bottom: var(--rule-light); background: var(--surface); }
.trust-bar-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 var(--s4); display: grid; grid-template-columns: repeat(4,1fr); }
.trust-item { padding: 24px var(--s3); border-right: var(--rule-light); display: flex; flex-direction: column; gap: 4px; }
.trust-item:last-child { border-right: none; }
.trust-value { font-size: 30px; font-weight: 700; color: var(--navy); letter-spacing: -0.02em; line-height: 1; }
.trust-label { font-size: 12px; color: var(--text-tertiary); font-weight: 300; line-height: 1.4; }

/* ─────────────────────────────────────────
   MAP SECTION
───────────────────────────────────────── */
.map-section {
  padding: var(--s6) var(--s4);
  background: var(--navy);
  border-top: var(--rule-light);
  border-bottom: 3px solid var(--gold);
}
.map-section-inner { max-width: var(--max-w); margin: 0 auto; }
.map-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: var(--s4);
  flex-wrap: wrap;
  gap: var(--s3);
}
.map-title {
  font-size: clamp(20px, 2.5vw, 28px);
  font-weight: 700;
  color: var(--white);
  letter-spacing: -0.02em;
  line-height: 1.2;
}
.map-title em { font-style: italic; font-weight: 400; color: var(--gold); }
.map-legend {
  display: flex;
  align-items: center;
  gap: var(--s3);
  flex-wrap: wrap;
}
.map-legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.04em;
}
.map-legend-dot-primary {
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--gold); flex-shrink: 0;
}
.map-legend-dot-secondary {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,0.3); flex-shrink: 0;
}
.map-wrap {
  position: relative;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8px;
  overflow: hidden;
}
.map-source {
  margin-top: var(--s2);
  font-size: 10px;
  color: rgba(255,255,255,0.2);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────
   SIMULATOR SECTION
───────────────────────────────────────── */
.simulator-section { padding: var(--s6) var(--s4); }
.simulator-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.simulator-feature-list { list-style: none; display: flex; flex-direction: column; gap: 0; margin-top: var(--s4); margin-bottom: var(--s4); }
.sim-feature { display: flex; gap: 16px; padding: var(--s2) 0; border-bottom: var(--rule-light); }
.sim-feature:first-child { border-top: var(--rule-light); }
.sim-feature-mark {
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--gold-pale);
  border: 1px solid rgba(240,180,41,0.3);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 2px;
}
.sim-feature-mark::after { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--gold); }
.sim-feature-text { font-size: 14px; color: var(--text-secondary); line-height: 1.6; font-weight: 300; }
.sim-feature-text strong { color: var(--text-primary); font-weight: 600; display: block; margin-bottom: 2px; font-size: 13px; }

/* App mockup */
.app-mockup {
  background: var(--surface);
  border: var(--rule-light);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(10,37,64,0.1);
}
.app-mockup-bar {
  background: var(--navy);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 2px solid var(--gold);
}
.app-mockup-dots { display: flex; gap: 5px; }
.app-mockup-dot { width: 8px; height: 8px; border-radius: 50%; }
.app-mockup-dot:nth-child(1) { background: rgba(255,255,255,0.15); }
.app-mockup-dot:nth-child(2) { background: rgba(255,255,255,0.1); }
.app-mockup-dot:nth-child(3) { background: rgba(255,255,255,0.07); }
.app-mockup-title { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-left: 4px; }
.app-mockup-body { padding: var(--s3); }
.app-control { margin-bottom: var(--s3); }
.app-control-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--text-tertiary); margin-bottom: 6px; display: block;
}
.app-select {
  width: 100%; background: var(--white); border: var(--rule-light); border-radius: 4px;
  padding: 9px 12px; font-size: 13px; font-weight: 500; color: var(--navy);
  display: flex; align-items: center; justify-content: space-between;
}
.app-select-arrow { color: var(--text-tertiary); font-size: 10px; }
.app-slider-row { display: flex; align-items: center; gap: 12px; }
.app-slider-track {
  flex: 1; height: 4px; background: var(--border); border-radius: 2px; position: relative;
}
.app-slider-fill {
  position: absolute; left: 0; top: 0; bottom: 0; border-radius: 2px; background: var(--blue);
}
.app-slider-thumb {
  position: absolute; top: 50%; transform: translate(-50%,-50%);
  width: 14px; height: 14px; border-radius: 50%; background: var(--white);
  border: 2px solid var(--blue); box-shadow: 0 1px 4px rgba(10,37,64,0.2);
}
.app-slider-val { font-size: 13px; font-weight: 700; color: var(--navy); min-width: 36px; text-align: right; }
.app-divider { height: 1px; background: var(--border); margin: var(--s2) 0; }
.app-output-label {
  font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--text-tertiary); margin-bottom: var(--s2); display: block;
}
.app-output-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 12px;
  background: var(--white); border: var(--rule-light);
  border-left: 3px solid var(--gold); border-radius: 0 4px 4px 0;
  margin-bottom: 6px;
}
.app-output-row-label { font-size: 11px; color: var(--text-secondary); }
.app-output-row-val { font-size: 17px; font-weight: 700; color: var(--navy); letter-spacing: -0.01em; }
.app-output-row-val span { font-size: 10px; font-weight: 400; color: var(--text-tertiary); margin-left: 2px; }
.app-cta-row {
  margin-top: var(--s3); padding: var(--s2) var(--s3);
  background: var(--navy); border-radius: 4px;
  display: flex; align-items: center; justify-content: space-between;
}
.app-cta-text { font-size: 11px; color: rgba(255,255,255,0.4); }
.app-cta-btn {
  font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--navy); background: var(--gold); padding: 6px 14px; border-radius: 3px;
}

/* Output cards */
.output-grid { display: grid; grid-template-columns: 1fr; gap: var(--s2); }
.output-card {
  background: var(--white); border: var(--rule-light);
  border-left: 3px solid var(--gold); border-radius: 0 6px 6px 0;
  padding: var(--s2) var(--s3);
  transition: transform 0.18s var(--ease), box-shadow 0.18s;
}
.output-card:hover { transform: translateX(3px); box-shadow: 0 4px 20px rgba(10,37,64,0.07); }
.output-card-num { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 4px; }
.output-card-title { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
.output-card-body { font-size: 13px; color: var(--text-secondary); line-height: 1.55; font-weight: 300; }
.output-card-eg { margin-top: 8px; font-size: 11px; color: var(--blue); background: var(--blue-pale); padding: 6px 10px; border-radius: 4px; line-height: 1.5; }
.output-card-eg strong { color: var(--navy); font-weight: 600; display: block; margin-bottom: 1px; }

/* ─────────────────────────────────────────
   DIFFERENTIATION
───────────────────────────────────────── */
.distinction { background: var(--surface); padding: var(--s6) var(--s4); border-top: var(--rule-light); border-bottom: var(--rule-light); }
.distinction-inner { max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.compare-table { width: 100%; border-collapse: collapse; font-size: 13px; background: var(--white); border-radius: 6px; overflow: hidden; border: var(--rule-light); box-shadow: 0 2px 12px rgba(10,37,64,0.05); }
.compare-table thead { background: var(--navy); }
.compare-table th { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 12px 16px; text-align: left; }
.compare-table th:first-child  { color: rgba(255,255,255,0.3); }
.compare-table th:nth-child(2) { color: rgba(255,255,255,0.45); }
.compare-table th:nth-child(3) { color: var(--gold); }
.compare-table td { padding: 11px 16px; border-bottom: var(--rule-light); vertical-align: top; line-height: 1.5; }
.compare-table td:first-child  { color: var(--text-tertiary); font-size: 12px; }
.compare-table td:nth-child(2) { color: var(--text-secondary); font-weight: 300; }
.compare-table td:nth-child(3) { color: var(--navy); font-weight: 500; }
.compare-table tr:last-child td { border-bottom: none; }
.compare-table tbody tr:hover td { background: var(--blue-pale); }

/* ─────────────────────────────────────────
   LIVE CONTEXT
───────────────────────────────────────── */
.live-section { padding: var(--s6) var(--s4); border-bottom: var(--rule-light); }
.live-inner { max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
.live-tag {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--navy); background: var(--gold-pale); border: 1px solid rgba(240,180,41,0.4);
  padding: 5px 14px; border-radius: 20px; margin-bottom: var(--s3);
}
.live-tag::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--gold); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(0.8);} }
.live-title { font-size: clamp(22px,2.8vw,32px); font-weight: 700; color: var(--navy); line-height: 1.2; margin-bottom: var(--s3); letter-spacing: -0.02em; }
.live-body { font-size: 15px; color: var(--text-secondary); line-height: 1.75; margin-bottom: var(--s2); font-weight: 300; }
.live-body strong { color: var(--text-primary); font-weight: 600; }
.live-stats { display: flex; flex-direction: column; gap: var(--s2); }
.live-stat { display: flex; align-items: center; gap: 20px; padding: var(--s2) var(--s3); background: var(--surface); border: var(--rule-light); border-left: 3px solid var(--gold); border-radius: 0 6px 6px 0; }
.live-stat-value { font-size: 30px; font-weight: 700; color: var(--navy); white-space: nowrap; letter-spacing: -0.02em; min-width: 76px; }
.live-stat-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.5; font-weight: 300; }
.live-stat-desc strong { color: var(--text-primary); font-weight: 600; display: block; margin-bottom: 1px; font-size: 12px; }

/* ─────────────────────────────────────────
   ANALYSIS
───────────────────────────────────────── */
.analysis-section { padding: var(--s6) var(--s4); background: var(--surface); border-bottom: var(--rule-light); }
.analysis-section-inner { max-width: var(--max-w); margin: 0 auto; }
.analysis-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: var(--s3); margin-top: var(--s4); }
.analysis-card {
  background: var(--white); border: var(--rule-light); border-top: 3px solid var(--gold);
  border-radius: 0 0 6px 6px; padding: var(--s3); text-decoration: none;
  display: flex; flex-direction: column; transition: transform 0.2s var(--ease), box-shadow 0.2s;
}
.analysis-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(10,37,64,0.08); }
.analysis-card-chokepoint { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; }
.analysis-card-title { font-size: 16px; font-weight: 700; color: var(--navy); line-height: 1.25; letter-spacing: -0.01em; margin-bottom: 10px; flex: 1; }
.analysis-card-body { font-size: 13px; color: var(--text-secondary); line-height: 1.6; font-weight: 300; margin-bottom: var(--s2); }
.analysis-card-stat { font-size: 11px; font-weight: 500; color: var(--blue); background: var(--blue-pale); padding: 6px 10px; border-radius: 4px; margin-bottom: var(--s2); line-height: 1.4; }
.analysis-card-link { font-size: 12px; font-weight: 600; color: var(--blue); display: inline-flex; align-items: center; gap: 4px; margin-top: auto; }
.analysis-card-link::after { content: '→'; }

/* ─────────────────────────────────────────
   FOR WHOM
───────────────────────────────────────── */
.audience-section { padding: var(--s6) var(--s4); border-bottom: var(--rule-light); }
.audience-inner { max-width: var(--max-w); margin: 0 auto; }
.audience-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: var(--s3); margin-top: var(--s4); }
.aud-card { background: var(--white); border: var(--rule-light); border-radius: 6px; padding: var(--s3) var(--s4); transition: border-color 0.2s,box-shadow 0.2s; }
.aud-card:hover { border-color: rgba(240,180,41,0.5); box-shadow: 0 6px 24px rgba(10,37,64,0.06); }
.aud-role { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); margin-bottom: var(--s1); }
.aud-title { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: var(--s2); line-height: 1.2; letter-spacing: -0.01em; }
.aud-body { font-size: 14px; color: var(--text-secondary); line-height: 1.65; margin-bottom: var(--s2); font-weight: 300; }
.aud-num { font-size: 12px; font-weight: 500; color: var(--blue); background: var(--blue-pale); padding: 7px 12px; border-radius: 4px; display: inline-block; line-height: 1.4; }

/* ─────────────────────────────────────────
   CTA
───────────────────────────────────────── */
.cta-section { padding: var(--s6) var(--s4); background: var(--navy); }
.cta-inner { max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 1fr auto; gap: 80px; align-items: center; }
.cta-title { font-size: clamp(26px,3vw,40px); font-weight: 700; color: var(--white); line-height: 1.15; margin-bottom: var(--s2); letter-spacing: -0.02em; }
.cta-title em { font-style: italic; font-weight: 400; color: var(--gold); }
.cta-sub { font-size: 15px; color: rgba(255,255,255,0.45); max-width: 520px; line-height: 1.7; font-weight: 300; }
.cta-right { display: flex; flex-direction: column; align-items: flex-start; gap: var(--s2); min-width: 280px; }
.cta-form { display: flex; flex-direction: column; gap: var(--s1); width: 100%; }
.cta-input {
  font-family: var(--font); font-size: 14px; font-weight: 400; color: var(--white);
  background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);
  border-radius: 4px; padding: 12px 16px; width: 100%; outline: none;
  transition: border-color 0.15s, background 0.15s;
}
.cta-input::placeholder { color: rgba(255,255,255,0.25); }
.cta-input:focus { border-color: var(--gold); background: rgba(255,255,255,0.1); }
.cta-submit { width: 100%; }
.cta-note { font-size: 11px; color: rgba(255,255,255,0.2); letter-spacing: 0.02em; }

/* ─────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────── */
@media (max-width: 1000px) {
  .hero { grid-template-columns: 1fr; }
  .sim-card { display: none; }
  .simulator-inner { grid-template-columns: 1fr; gap: var(--s4); }
  .distinction-inner { grid-template-columns: 1fr; gap: var(--s4); }
  .live-inner { grid-template-columns: 1fr; gap: var(--s4); }
  .cta-inner { grid-template-columns: 1fr; gap: var(--s4); }
  .cta-right { min-width: unset; width: 100%; max-width: 400px; }
}
@media (max-width: 800px) {
  .trust-bar-inner { grid-template-columns: repeat(2,1fr); }
  .analysis-grid { grid-template-columns: 1fr; }
  .audience-grid { grid-template-columns: 1fr; }
}
</style>

<!-- ══════════════════════════════
     HERO
══════════════════════════════ -->
<section class="hero">
  <div>
    <div class="hero-kicker"><span class="hero-kicker-line"></span>Trade Risk Intelligence</div>
    <h1 class="hero-headline">
      The model that turns<br>
      <em>trade risk news</em><br>
      into numbers.
    </h1>
    <p class="hero-tagline">
      The news tells you what happened.<br>
      <strong>Narrows tells you what it costs.</strong>
    </p>
    <p class="hero-sub">
      Dollar-denominated exposure, rerouting cost, and fleet-at-risk — built for the underwriters, traders, and lenders who have to put a number on it.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn btn-blue">Request a demo</a>
      <a href="/analysis" class="btn-ghost">Read the analysis</a>
    </div>
  </div>

  <div class="sim-card">
    <div class="sim-card-topbar">
      <div class="sim-card-dots">
        <div class="sim-card-dot"></div>
        <div class="sim-card-dot"></div>
        <div class="sim-card-dot"></div>
      </div>
      <span class="sim-card-url">app.narrows.io</span>
    </div>
    <div class="sim-card-header">
      <div class="sim-card-eyebrow">Scenario simulation output</div>
      <div class="sim-card-scenario">
        <strong>Strait of Hormuz — 100% closure, 30 days</strong><br>
        All commodities · Sensitivity 1.00 · No alternative route · 2023 data
      </div>
    </div>
    <div class="sim-row"><span class="sim-row-label">Value at risk</span><span class="sim-row-value">$13.8B<span class="unit">USD</span></span></div>
