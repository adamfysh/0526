<link href="https://cdn.jsdelivr.net/npm/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
 
<script>
// ── CHOKEPOINT DATA ──────────────────────────────────────
const CHOKEPOINTS = [
  // PRIMARY — gold, large
  {
    name: "Strait of Hormuz",
    lat: 26.6, lng: 56.3,
    stat: "$31.8B at risk · 30d closure",
    primary: true
  },
  {
    name: "Strait of Malacca",
    lat: 2.5, lng: 102.0,
    stat: "$62.4B at risk · 14d closure",
    primary: true
  },
  {
    name: "Suez Canal",
    lat: 30.5, lng: 32.3,
    stat: "+14 days via Cape · VLCC",
    primary: true
  },
  {
    name: "Panama Canal",
    lat: 9.1, lng: -79.7,
    stat: "+8 days Atlantic reroute",
    primary: true
  },
  // SECONDARY — faded, smaller
  { name: "Bab el-Mandeb",       lat: 12.6,  lng: 43.4,   primary: false },
  { name: "Strait of Gibraltar", lat: 35.9,  lng: -5.5,   primary: false },
  { name: "Lombok Strait",       lat: -8.7,  lng: 115.7,  primary: false },
  { name: "Tsushima Strait",     lat: 34.2,  lng: 129.4,  primary: false },
  { name: "Torres Strait",       lat: -10.5, lng: 141.8,  primary: false },
  { name: "Cape of Good Hope",   lat: -34.4, lng: 18.5,   primary: false },
  { name: "Danish Straits",      lat: 56.0,  lng: 10.5,   primary: false },
  { name: "Strait of Sicily",    lat: 37.1,  lng: 11.3,   primary: false },
  { name: "Cape Horn",           lat: -55.9, lng: -67.3,  primary: false },
  { name: "Sunda Strait",        lat: -6.0,  lng: 105.8,  primary: false },
  { name: "Dover Strait",        lat: 51.1,  lng: 1.4,    primary: false },
  { name: "Øresund",             lat: 55.9,  lng: 12.7,   primary: false },
];
 
// ── INIT MAP ─────────────────────────────────────────────
// Replace YOUR_MAPTILER_KEY with your actual MapTiler API key
const MAPTILER_KEY = 'WhGN4xYSsxgSvljOv6UB';
const STYLE_URL = `https://api.maptiler.com/maps/019daf09-19a6-7ff8-acee-a15542062b80/style.json?key=${MAPTILER_KEY}`;
 
let popup = null;
 
window.addEventListener('load', () => {
  const map = new maplibregl.Map({
    container: 'narrows-map',
    style: STYLE_URL,
    center: [40, 15],
    zoom: 1.8,
    minZoom: 1,
    maxZoom: 8,
    attributionControl: false,
    scrollZoom: false, // prevent scroll hijack on page
  });
 
  map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'bottom-right');
 
  map.on('load', () => {
 
    // ── Add chokepoint source ──
    map.addSource('chokepoints', {
      type: 'geojson',
      data: {
        type: 'FeatureCollection',
        features: CHOKEPOINTS.map(cp => ({
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [cp.lng, cp.lat] },
          properties: {
            name: cp.name,
            stat: cp.stat || '',
            primary: cp.primary,
          }
        }))
      }
    });
 
    // ── Primary glow ring ──
    map.addLayer({
      id: 'cp-primary-ring',
      type: 'circle',
      source: 'chokepoints',
      filter: ['==', ['get', 'primary'], true],
      paint: {
        'circle-radius': 14,
        'circle-color': 'rgba(240, 180, 41, 0.12)',
        'circle-stroke-width': 1,
        'circle-stroke-color': 'rgba(240, 180, 41, 0.35)',
      }
    });
 
    // ── Primary dot ──
    map.addLayer({
      id: 'cp-primary-dot',
      type: 'circle',
      source: 'chokepoints',
      filter: ['==', ['get', 'primary'], true],
      paint: {
        'circle-radius': 6,
        'circle-color': '#F0B429',
        'circle-stroke-width': 1.5,
        'circle-stroke-color': 'rgba(255,255,255,0.3)',
      }
    });
 
    // ── Secondary dot ──
    map.addLayer({
      id: 'cp-secondary-dot',
      type: 'circle',
      source: 'chokepoints',
      filter: ['==', ['get', 'primary'], false],
      paint: {
        'circle-radius': 4,
        'circle-color': 'rgba(143, 165, 187, 0.5)',
        'circle-stroke-width': 1,
        'circle-stroke-color': 'rgba(143, 165, 187, 0.2)',
      }
    });
 
    // ── Primary labels ──
    map.addLayer({
      id: 'cp-primary-label',
      type: 'symbol',
      source: 'chokepoints',
      filter: ['==', ['get', 'primary'], true],
      layout: {
        'text-field': ['get', 'name'],
        'text-font': ['Open Sans Semibold', 'Arial Unicode MS Bold'],
        'text-size': 10,
        'text-offset': [0, 1.6],
        'text-anchor': 'top',
        'text-allow-overlap': false,
      },
      paint: {
        'text-color': '#F0B429',
        'text-halo-color': 'rgba(6, 15, 26, 0.85)',
        'text-halo-width': 2,
      }
    });
 
    // ── Hover popup on primary points ──
    map.on('mouseenter', 'cp-primary-dot', (e) => {
      map.getCanvas().style.cursor = 'pointer';
      const props = e.features[0].properties;
      const coords = e.features[0].geometry.coordinates.slice();
 
      if (popup) popup.remove();
      popup = new maplibregl.Popup({
        closeButton: false,
        closeOnClick: false,
        className: 'narrows-popup',
        offset: 12,
      })
        .setLngLat(coords)
        .setHTML(`
          <div class="np-name">${props.name}</div>
          <div class="np-stat">${props.stat}</div>
        `)
        .addTo(map);
    });
 
    map.on('mouseleave', 'cp-primary-dot', () => {
      map.getCanvas().style.cursor = '';
      if (popup) { popup.remove(); popup = null; }
    });
 
    // ── Hover on secondary too ──
    map.on('mouseenter', 'cp-secondary-dot', (e) => {
      map.getCanvas().style.cursor = 'default';
      const props = e.features[0].properties;
      const coords = e.features[0].geometry.coordinates.slice();
      if (popup) popup.remove();
      popup = new maplibregl.Popup({
        closeButton: false,
        closeOnClick: false,
        className: 'narrows-popup narrows-popup-secondary',
        offset: 10,
      })
        .setLngLat(coords)
        .setHTML(`<div class="np-name-secondary">${props.name}</div>`)
        .addTo(map);
    });
 
    map.on('mouseleave', 'cp-secondary-dot', () => {
      map.getCanvas().style.cursor = '';
      if (popup) { popup.remove(); popup = null; }
    });
 
  }); // end map.on('load')
}); // end window.on('load')
</script>
 
