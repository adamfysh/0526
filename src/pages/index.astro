<script is:inline>
(function() {
  // Wait for Leaflet to be available
  function initMiniMap() {
    if (typeof L === 'undefined') { setTimeout(initMiniMap, 100); return; }
    var mapEl = document.getElementById('pri-mini-map');
    if (!mapEl) return;

    var map = L.map('pri-mini-map', {
      center: [20, 10], zoom: 2,
      zoomControl: false, attributionControl: false,
      dragging: false, scrollWheelZoom: false,
      doubleClickZoom: false, touchZoom: false,
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
      subdomains: 'abcd', maxZoom: 19,
    }).addTo(map);

    var COLOURS = { High: '#E8952A', Critical: '#F0B429' };

    fetch('/pri_ports.json')
      .then(function(r) { return r.json(); })
      .then(function(ports) {
        ports.forEach(function(p) {
          if (p.t !== 'High' && p.t !== 'Critical') return;
          var c = COLOURS[p.t];
          L.circleMarker([p.la, p.lo], {
            radius: p.t === 'Critical' ? 6 : 4,
            fillColor: c, fillOpacity: p.t === 'Critical' ? 0.95 : 0.75,
            color: p.t === 'Critical' ? c : 'transparent',
            weight: p.t === 'Critical' ? 1.5 : 0,
          }).addTo(map);
        });
      });
  }
  initMiniMap();
})();
</script>
