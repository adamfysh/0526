    </div>
    <div class="cta-right">
      <div class="cta-form">
        <input type="text" id="demo-honey" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;pointer-events:none" />
        <input type="email" class="cta-input" placeholder="your@organisation.com" id="demo-email" autocomplete="email" />
        <button class="btn btn-gold cta-submit" id="demo-btn">Request a demo</button>
      </div>
      <span class="cta-note">fysh@narrows.io · A person will reply.</span>
    </div>
  </div>
</section>

<script>
function isValidEmailDemo(email: string): boolean {
  return /^[^\s@]+@[^\s@]{2,}\.[^\s@]{2,}$/.test(email);
}
function handleDemoRequest() {
  const input = document.getElementById('demo-email') as HTMLInputElement;
  const honey = document.getElementById('demo-honey') as HTMLInputElement;
  const email = input.value.trim();
  if (honey?.value) return;
  if (!isValidEmailDemo(email)) {
    input.style.borderColor = 'rgba(192,57,43,0.8)';
    input.style.boxShadow = '0 0 0 3px rgba(192,57,43,0.15)';
    input.placeholder = 'Please enter a valid email address';
    setTimeout(() => {
      input.style.borderColor = ''; input.style.boxShadow = '';
      input.placeholder = 'your@organisation.com';
    }, 2000);
    return;
  }
  window.location.href = `mailto:fysh@narrows.io?subject=Demo request — Narrows&body=Request from: ${email}%0A%0AOrganisation:%0ARole:%0APrimary corridor of interest:%0A%0AContext (optional):`;
}
document.getElementById('demo-btn')?.addEventListener('click', handleDemoRequest);
document.getElementById('demo-email')?.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter') handleDemoRequest();
});
</script>

