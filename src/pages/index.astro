<section class="cta-section" id="contact">
  <div class="cta-inner">
    <div>
      <h2 class="cta-title">Every assumption is a <em>conversation</em>,<br>not a constraint.</h2>
      <p class="cta-sub">If your view of bypass capacity, vessel rates, or corridor sensitivity differs from our defaults, that is a one-parameter change. The demo runs your scenario, in front of you, with an analyst present. No sales funnel. A person will reply.</p>
    </div>
    <div class="cta-right">
      <div class="cta-form">
        <input type="email" class="cta-input" placeholder="your@organisation.com" id="demo-email" />
        <button class="btn btn-gold cta-submit" id="demo-btn">Request a demo</button>
      </div>
      <span class="cta-note">fysh@narrows.io · A person will reply.</span>
    </div>
  </div>
</section>

<script>
function handleDemoRequest() {
  const input = document.getElementById('demo-email') as HTMLInputElement;
  const email = input.value.trim();
  if (!email || !email.includes('@')) {
    input.style.borderColor = 'rgba(192,57,43,0.8)';
    input.style.boxShadow = '0 0 0 3px rgba(192,57,43,0.15)';
    setTimeout(() => { input.style.borderColor = ''; input.style.boxShadow = ''; }, 1600);
    return;
  }
  window.location.href = `mailto:fysh@narrows.io?subject=Demo request — Narrows&body=Request from: ${email}%0A%0AOrganisation:%0ARole:%0APrimary corridor of interest:%0A%0AContext (optional):`;
}
document.getElementById('demo-btn')?.addEventListener('click', handleDemoRequest);
document.getElementById('demo-email')?.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter') handleDemoRequest();
});
</script>

