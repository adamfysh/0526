---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

// Read at build time — process.cwd() is always the repo root during Astro SSG
const priDataStr = readFileSync(join(process.cwd(), 'src/data/pri.json'), 'utf-8');
---

<BaseLayout
  title="Port Risk Index — Narrows"
  description="3804 ports scored across four dimensions of risk: accessibility, reliability, concentration, and stability. The Narrows Port Risk Index."
>

<!-- Data baked in at build time — no fetch, no runtime dependency -->
<Fragment set:html={`<script>window.__PRI__=${priDataStr};</script>`} />

<style>
/* ─────────────────────────────────────────
   PRI PAGE — PAGE-SCOPED STYLES
───────────────────────────────────────── */

/* Hero */
.pri-hero {
  padding: 120px var(--s4) var(--s5);
  max-width: var(--max-w);
  margin: 0 auto;
}
.pri-hero-kicker {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--text-tertiary); margin-bottom: var(--s2);
}
.pri-hero-kicker::before { content: ''; width: 32px; height: 1px; background: var(--gold); }
.pri-hero h1 {
  font-size: clamp(32px, 4vw, 52px); font-weight: 700; color: var(--navy);
  line-height: 1.08; letter-spacing: -0.03em; margin-bottom: var(--s2);
}
.pri-hero h1 em { font-style: italic; font-weight: 400; color: var(--blue-light); }
.pri-hero-lead {
  font-size: 17px; color: var(--text-secondary); line-height: 1.7;
  font-weight: 300; max-width: 620px; margin-bottom: var(--s4);
}

/* Stats strip */
.pri-stats {
  display: flex; gap: 0; border-top: var(--rule-light); border-bottom: var(--rule-light);
  background: var(--surface);
}
.pri-stat {
  padding: 18px var(--s4); border-right: var(--rule-light);
  display: flex; flex-direction: column; gap: 2px;
}
.pri-stat:last-child { border-right: none; }
.pri-stat-val { font-size: 32px; font-weight: 700; color: var(--navy); letter-spacing: -0.02em; line-height: 1; }
.pri-stat-lbl { font-size: 12px; color: var(--text-secondary); font-weight: 400; }

/* Explorer shell */
.pri-explorer {
  background: var(--surface);
  border-bottom: 3px solid var(--gold);
}
.pri-explorer-inner {
  max-width: var(--max-w); margin: 0 auto; padding: var(--s4);
}

/* Search */
.pri-search-wrap { position: relative; margin-bottom: var(--s4); }
.pri-search-input {
  width: 100%; font-family: var(--font); font-size: 16px; font-weight: 400;
  color: var(--text-primary); background: var(--white);
  border: 2px solid var(--border); border-radius: 6px;
  padding: 16px 20px 16px 48px; outline: none;
  transition: border-color 0.15s, box-shadow 0.15s;
  box-shadow: 0 2px 8px rgba(10,37,64,0.05);
}
.pri-search-input:focus {
  border-color: var(--gold); box-shadow: 0 0 0 4px rgba(240,180,41,0.1);
}
.pri-search-input::placeholder { color: var(--text-tertiary); }
.pri-search-icon {
  position: absolute; left: 16px; top: 50%; transform: translateY(-50%);
  font-size: 18px; color: var(--text-tertiary); pointer-events: none;
}
.pri-search-clear {
  position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer; color: var(--text-tertiary);
  font-size: 18px; line-height: 1; padding: 4px; display: none;
}
.pri-search-clear.visible { display: block; }

/* Typeahead dropdown */
.pri-dropdown {
  position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 50;
  background: var(--white); border: var(--rule-light); border-radius: 6px;
  box-shadow: 0 12px 40px rgba(10,37,64,0.12); overflow: hidden; display: none;
}
.pri-dropdown.open { display: block; }
.pri-dd-item {
  padding: 11px 20px; cursor: pointer; display: flex; align-items: center;
  justify-content: space-between; border-bottom: var(--rule-light);
  transition: background 0.1s;
}
.pri-dd-item:last-child { border-bottom: none; }
.pri-dd-item:hover, .pri-dd-item.focused { background: var(--blue-pale); }
.pri-dd-name { font-size: 14px; font-weight: 600; color: var(--navy); }
.pri-dd-country { font-size: 12px; color: var(--text-tertiary); }
.pri-dd-score {
  font-size: 13px; font-weight: 700; color: var(--navy);
  background: var(--surface); padding: 3px 8px; border-radius: 4px;
}
.pri-dd-none { padding: 16px 20px; font-size: 13px; color: var(--text-tertiary); }

/* Detail panel */
.pri-detail {
  display: none; margin-bottom: var(--s4);
  background: var(--white); border: var(--rule-light); border-radius: 8px;
  overflow: hidden; box-shadow: 0 4px 16px rgba(10,37,64,0.06);
}
.pri-detail.visible { display: block; }
.pri-detail-header {
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap;
  gap: var(--s2); padding: 20px var(--s4); border-bottom: var(--rule-light);
}
.pri-detail-name { font-size: 22px; font-weight: 700; color: var(--navy); letter-spacing: -0.015em; }
.pri-detail-meta { font-size: 13px; color: var(--text-secondary); font-weight: 400; margin-top: 2px; }
.pri-detail-badge {
  display: flex; flex-direction: column; align-items: flex-end; gap: 2px;
  background: var(--navy); border-radius: 6px; padding: 12px 20px;
  flex-shrink: 0; text-align: right;
}
.pri-detail-badge-lbl {
  font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(255,255,255,0.35); white-space: nowrap;
}
.pri-detail-badge-score { font-size: 36px; font-weight: 700; color: var(--gold); letter-spacing: -0.03em; line-height: 1; }

/* Dimension cards */
.pri-dim-row {
  display: grid; grid-template-columns: repeat(4, 1fr);
  border-bottom: var(--rule-light);
}
.pri-dim-card {
  padding: 18px 20px; border-right: var(--rule-light);
}
.pri-dim-card:last-child { border-right: none; }
.pri-dc-lbl { font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 2px; }
.pri-dc-name { font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 10px; }
.pri-dc-score { font-size: 32px; font-weight: 700; color: var(--navy); letter-spacing: -0.03em; line-height: 1; margin-bottom: 8px; }
.pri-dc-score span { font-size: 13px; font-weight: 300; color: var(--text-tertiary); margin-left: 2px; }
.pri-dc-bar { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
.pri-dc-fill { height: 100%; border-radius: 2px; transition: width 0.4s var(--ease); }
.pri-dc-subs {
  margin-top: 10px; display: flex; flex-direction: column; gap: 4px;
  border-top: var(--rule-light); padding-top: 10px;
}
.pri-dc-sub-row { display: flex; justify-content: space-between; align-items: center; }
.pri-dc-sub-lbl { font-size: 9px; color: var(--text-tertiary); font-weight: 300; }
.pri-dc-sub-val { font-size: 10px; font-weight: 600; color: var(--text-secondary); }

/* Histogram */
.pri-hist-section {
  padding: 18px var(--s4) 14px;
  border-bottom: var(--rule-light);
}
.pri-hist-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 10px;
}
.pri-hist-title {
  font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text-tertiary);
}
.pri-hist-port-lbl { font-size: 11px; color: var(--blue); font-weight: 600; }
.pri-hist-svg-wrap { width: 100%; height: 80px; }
.pri-hist-svg-wrap svg { width: 100%; height: 100%; display: block; }
.pri-hist-axis {
  display: flex; justify-content: space-between; margin-top: 4px;
  font-size: 9px; color: var(--text-tertiary); padding: 0 2px;
}

/* ── Full-width table section ── */
.pri-table-section {
  max-width: var(--max-w); margin: 0 auto; padding: 0 var(--s4) var(--s6);
}
.pri-table-controls {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--s3) 0 var(--s2); flex-wrap: wrap; gap: var(--s2);
}
.pri-table-count { font-size: 13px; color: var(--text-tertiary); font-weight: 300; }
.pri-table-count strong { color: var(--text-primary); font-weight: 600; }
.pri-table-wrap {
  background: var(--white); border: var(--rule-light); border-radius: 8px;
  overflow-x: hidden; overflow-y: auto; max-height: 560px;
  box-shadow: 0 2px 12px rgba(10,37,64,0.05);
}
.pri-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.pri-table thead { background: var(--navy); position: sticky; top: 0; z-index: 10; }
.pri-table th {
  padding: 12px 14px; text-align: left; user-select: none; cursor: pointer;
  white-space: nowrap; transition: background 0.1s;
}
.pri-table th:hover { background: rgba(255,255,255,0.05); }
.pri-table .th-inner {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
}
.pri-table th:nth-child(1) .th-inner { color: rgba(255,255,255,0.3); }
.pri-table th:nth-child(2) .th-inner,
.pri-table th:nth-child(3) .th-inner { color: rgba(255,255,255,0.5); }
.pri-table th:nth-child(4) .th-inner { color: var(--gold); }
.pri-table th:nth-child(n+5) .th-inner { color: rgba(255,255,255,0.4); }
.sort-arrow { font-size: 8px; opacity: 0.4; }
.sort-arrow.active { opacity: 1; }
.pri-table td { padding: 10px 14px; border-bottom: var(--rule-light); vertical-align: middle; }
.pri-table tr:last-child td { border-bottom: none; }
.pri-table tbody tr { cursor: pointer; transition: background 0.1s; }
.pri-table tbody tr:hover td { background: var(--blue-pale); }
.pri-table tbody tr.selected td { background: rgba(240,180,41,0.07); }
.pri-table tbody tr.selected td:nth-child(4) { font-weight: 700; }
.td-rank { color: var(--text-tertiary); font-size: 12px; min-width: 50px; }
.td-port { font-weight: 600; color: var(--navy); }
.td-country { color: var(--text-secondary); font-weight: 300; font-size: 12px; }
.td-score { font-weight: 700; font-size: 14px; font-variant-numeric: tabular-nums; }
.td-dim { font-size: 12px; color: var(--text-secondary); font-variant-numeric: tabular-nums; }

/* Score colour chips */
.score-chip {
  display: inline-block; padding: 3px 8px; border-radius: 3px;
  font-size: 13px; font-weight: 700;
}

/* Pagination */
.pri-pagination {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 0; flex-wrap: wrap; gap: var(--s2);
}
.pri-page-info { font-size: 12px; color: var(--text-tertiary); }
.pri-page-btns { display: flex; gap: 4px; }
.pri-page-btn {
  font-family: var(--font); font-size: 12px; font-weight: 500;
  padding: 6px 12px; border: var(--rule-light); border-radius: 4px;
  background: var(--white); color: var(--text-secondary);
  cursor: pointer; transition: background 0.12s, border-color 0.12s;
}
.pri-page-btn:hover { background: var(--blue-pale); border-color: var(--blue); color: var(--navy); }
.pri-page-btn.active { background: var(--navy); color: var(--white); border-color: var(--navy); }
.pri-page-btn:disabled { opacity: 0.35; cursor: default; }

/* Loading state */
.pri-loading {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: var(--s6) 0; gap: var(--s2); color: var(--text-tertiary);
}
.pri-spinner {
  width: 32px; height: 32px; border: 3px solid var(--border);
  border-top-color: var(--gold); border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.pri-loading-txt { font-size: 13px; font-weight: 300; }

/* Method note */
.pri-method {
  border-top: var(--rule-light);
  background: var(--surface);
  padding: var(--s5) var(--s4);
}
.pri-method-inner {
  max-width: var(--max-w); margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;
}
.pri-method-title { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: var(--s2); letter-spacing: -0.015em; }
.pri-method-body { font-size: 14px; color: var(--text-secondary); line-height: 1.7; font-weight: 300; margin-bottom: var(--s2); }
.pri-method-body strong { color: var(--text-primary); font-weight: 600; }
.pri-dim-legend { display: flex; flex-direction: column; gap: var(--s3); }
.pri-dim-legend-item { display: flex; align-items: flex-start; gap: 16px; }
.pri-dim-legend-dot { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
.pri-dim-legend-text h4 { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 4px; letter-spacing: -0.01em; }
.pri-dim-legend-text p { font-size: 13px; color: var(--text-secondary); font-weight: 300; line-height: 1.6; }

/* ─────────────────────────────────────────
   EMAIL GATE
───────────────────────────────────────── */
.pri-gate {
  position: fixed; inset: 0; z-index: 2000;
  background: rgba(10,37,64,0.88);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex; align-items: center; justify-content: center;
  padding: 24px;
  transition: opacity 0.4s ease;
}
.pri-gate.dismissing { opacity: 0; pointer-events: none; }
.pri-gate.hidden { display: none; }
.pri-gate-card {
  background: #fff;
  border-radius: 12px;
  padding: 48px 44px 40px;
  max-width: 464px;
  width: 100%;
  position: relative;
  box-shadow: 0 40px 100px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.06);
}
.pri-gate-eyebrow {
  display: flex; align-items: center; gap: 10px; margin-bottom: 18px;
}
.pri-gate-mark {
  width: 32px; height: 32px;
  background: var(--navy); border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.pri-gate-mark svg { width: 18px; height: 18px; }
.pri-gate-brand {
  font-size: 13px; font-weight: 700; letter-spacing: 0.04em;
  color: var(--navy); line-height: 1.2;
}
.pri-gate-brand-sub {
  font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--text-tertiary); display: block; margin-top: 1px;
}
.pri-gate-rule { height: 1px; background: var(--border); margin-bottom: 24px; }
.pri-gate-h {
  font-size: 26px; font-weight: 700; color: var(--navy);
  letter-spacing: -0.025em; line-height: 1.15; margin-bottom: 10px;
}
.pri-gate-h em { font-style: italic; font-weight: 400; color: var(--blue); }
.pri-gate-lead {
  font-size: 14px; color: var(--text-secondary); line-height: 1.65;
  font-weight: 300; margin-bottom: 28px;
}
.pri-gate-pills {
  display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 28px;
}
.pri-gate-pill {
  font-size: 11px; font-weight: 600; color: var(--navy);
  background: var(--surface); border: var(--rule-light);
  border-radius: 20px; padding: 4px 10px;
}
.pri-gate-fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
.pri-gate-input {
  font-family: var(--font); font-size: 15px; font-weight: 400;
  color: var(--text-primary); background: var(--white);
  border: 2px solid var(--border); border-radius: 6px;
  padding: 13px 16px; outline: none; width: 100%; box-sizing: border-box;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.pri-gate-input:focus {
  border-color: var(--gold); box-shadow: 0 0 0 4px rgba(240,180,41,0.12);
}
.pri-gate-input::placeholder { color: var(--text-tertiary); }
.pri-gate-btn {
  font-family: var(--font); font-size: 15px; font-weight: 700;
  color: var(--navy); background: var(--gold);
  border: none; border-radius: 6px; padding: 14px 24px;
  cursor: pointer; width: 100%; letter-spacing: 0.01em;
  transition: filter 0.15s, transform 0.1s;
}
.pri-gate-btn:hover:not(:disabled) { filter: brightness(1.06); }
.pri-gate-btn:active:not(:disabled) { transform: scale(0.99); }
.pri-gate-btn:disabled { opacity: 0.55; cursor: wait; }
.pri-gate-fine {
  font-size: 11px; color: var(--text-tertiary); font-weight: 300; line-height: 1.5;
  text-align: center; margin-top: 14px;
}
.pri-gate-error {
  font-size: 12px; color: #c0392b; margin-top: 8px;
  display: none; text-align: center;
}
.pri-gate-stats {
  display: flex; gap: 0; border-top: var(--rule-light); margin-top: 24px;
}
.pri-gate-stat {
  flex: 1; padding: 14px 0 0; text-align: center;
  border-right: var(--rule-light);
}
.pri-gate-stat:last-child { border-right: none; }
.pri-gate-stat-val {
  font-size: 22px; font-weight: 700; color: var(--navy);
  letter-spacing: -0.02em; line-height: 1; display: block;
}
.pri-gate-stat-lbl {
  font-size: 9px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text-tertiary); display: block; margin-top: 3px;
}

/* Responsive */
@media (max-width: 1000px) {
  .pri-dim-row { grid-template-columns: repeat(2, 1fr); }
  .pri-dim-card:nth-child(2) { border-right: none; }
  .pri-dim-card:nth-child(n+3) { border-top: var(--rule-light); }
  .pri-method-inner { grid-template-columns: 1fr; gap: var(--s4); }
}
@media (max-width: 700px) {
  .pri-stats { flex-wrap: wrap; }
  .pri-stat { flex: 1 1 45%; }
  .pri-dim-row { grid-template-columns: 1fr 1fr; }
  .pri-table th:nth-child(n+5), .pri-table td:nth-child(n+5) { display: none; }
}
</style>

<!-- ══════════════════════════════
     EMAIL GATE OVERLAY
══════════════════════════════ -->
<div class="pri-gate" id="pri-gate">
  <div class="pri-gate-card">

    <!-- Branding -->
    <div class="pri-gate-eyebrow">
      <div class="pri-gate-mark">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 3L20 8V16L12 21L4 16V8L12 3Z" stroke="#F0B429" stroke-width="1.5" fill="none"/>
          <path d="M12 7L17 10V14L12 17L7 14V10L12 7Z" fill="#F0B429" opacity="0.35"/>
        </svg>
      </div>
      <div class="pri-gate-brand">
        Narrows
        <span class="pri-gate-brand-sub">Port Risk Index</span>
      </div>
    </div>
    <div class="pri-gate-rule"></div>

    <!-- Headline -->
    <div class="pri-gate-h">3804 ports scored.<br><em>Free access, instant.</em></div>
    <p class="pri-gate-lead">
      The Narrows PRI scores every major port in the World Port Index across four dimensions:
      physical accessibility, operational reliability, trade concentration, and geopolitical stability.
      Enter your email for immediate access. No password, no waiting.
    </p>

    <!-- Teaser pills -->
    <div class="pri-gate-pills">
      <span class="pri-gate-pill">3804 ports</span>
      <span class="pri-gate-pill">195 countries</span>
      <span class="pri-gate-pill">4 risk dimensions</span>
      <span class="pri-gate-pill">16 indicators</span>
      <span class="pri-gate-pill">Sortable + searchable</span>
    </div>

    <!-- Form -->
    <form id="pri-gate-form" novalidate>
      <div class="pri-gate-fields">
        <input
          class="pri-gate-input"
          type="email"
          name="email"
          id="pri-gate-email"
          placeholder="Work email"
          required
          autocomplete="email"
        />
        <input
          class="pri-gate-input"
          type="text"
          name="company"
          id="pri-gate-company"
          placeholder="Company or vessel operator (optional)"
          autocomplete="organization"
        />
      </div>
      <button class="pri-gate-btn" type="submit" id="pri-gate-btn">
        Get free access →
      </button>
      <div class="pri-gate-error" id="pri-gate-error">
        Something went wrong. Please try again or email hello@narrows.ai
      </div>
    </form>

    <p class="pri-gate-fine">
      No spam. No password. We will only contact you when something material changes.
    </p>

    <!-- Mini stats -->
    <div class="pri-gate-stats">
      <div class="pri-gate-stat">
        <span class="pri-gate-stat-val">3804</span>
        <span class="pri-gate-stat-lbl">Ports</span>
      </div>
      <div class="pri-gate-stat">
        <span class="pri-gate-stat-val">195</span>
        <span class="pri-gate-stat-lbl">Countries</span>
      </div>
      <div class="pri-gate-stat">
        <span class="pri-gate-stat-val">16</span>
        <span class="pri-gate-stat-lbl">Indicators</span>
      </div>
      <div class="pri-gate-stat">
        <span class="pri-gate-stat-val">Free</span>
        <span class="pri-gate-stat-lbl">Always</span>
      </div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════
     HERO
══════════════════════════════ -->
<div class="pri-hero fade-up">
  <div class="pri-hero-kicker">Port Risk Index</div>
  <h1>3804 ports scored.<br><em>Four dimensions of risk.</em></h1>
  <p class="pri-hero-lead">
    The Narrows PRI scores every major port in the World Port Index across four dimensions:
    physical accessibility, operational reliability, trade concentration,
    and geopolitical stability. Each scored from independent source data,
    combined via geometric mean. Lower score is lower risk.
  </p>
</div>

<!-- Stats strip -->
<div class="pri-stats">
  <div class="pri-stat"><span class="pri-stat-val">3804</span><span class="pri-stat-lbl">Ports indexed · World Port Index universe</span></div>
  <div class="pri-stat"><span class="pri-stat-val">4</span><span class="pri-stat-lbl">Dimensions · Physical, operational, concentration, stability</span></div>
