<script is:inline>
(function() {
  'use strict';

  /* ── CONFIG ── */
  const DIM_COLORS = ['#378ADD', '#EF9F27', '#7F77DD', '#D85A30'];
  const EFF_MAX = 3.712; // empirical max

  /* ── STATE ── */
  let allPorts = [];
  let filteredPorts = [];
  let selectedPort = null;
  let sortCol = 'pri_score';
  let sortAsc = false;  // default: highest risk first
  let histBins = [];
  let globalMean = 0;

  /* ── DOM REFS ── */
  const searchEl    = document.getElementById('pri-search');
  const clearBtn    = document.getElementById('pri-clear');
  const dropdown    = document.getElementById('pri-dropdown');
  const detailEl    = document.getElementById('pri-detail');
  const tbodyEl     = document.getElementById('pri-tbody');
  const countEl     = document.getElementById('tbl-count');
  const histWrap    = document.getElementById('hist-wrap');

  /* ── SCORE → COLOUR ── */
  function scoreColor(v) {
    if (v === null || v === undefined) return '#8FA5BB';
    if (v >= 3.0)  return '#D85A30';
    if (v >= 2.5)  return '#EF9F27';
    if (v >= 2.0)  return '#1565A8';
    return '#378ADD';
  }
  function scoreChip(v, small) {
    if (v === null || v === undefined) return '—';
    const c = scoreColor(v);
    const bg = c + '18';
    const s = v.toFixed(2);
    if (small) return `<span class="td-dim" style="color:${c};font-weight:600">${s}</span>`;
    return `<span class="score-chip" style="color:${c};background:${bg}">${s}</span>`;
  }

  /* ── BUILD HISTOGRAM BINS ── */
  function buildBins(ports) {
    const N_BINS = 24;
    const MIN = 0.75, MAX = 3.75;
    const W = (MAX - MIN) / N_BINS;
    const counts = new Array(N_BINS).fill(0);
    ports.forEach(p => {
      const b = Math.min(Math.floor((p.pri_score - MIN) / W), N_BINS - 1);
      if (b >= 0) counts[b]++;
    });
    return { counts, min: MIN, max: MAX, w: W };
  }

  /* ── DRAW HISTOGRAM ── */
  function drawHistogram(portScore) {
    if (!histBins.counts) return;
    const { counts, min, max, w } = histBins;
    const N = counts.length;
    const maxC = Math.max(...counts);
    const W = 960, H = 80;
    const barW = Math.floor(W / N);

    let bars = '';
    counts.forEach((c, i) => {
      const x = i * barW;
      const h = maxC > 0 ? Math.round((c / maxC) * H) : 0;
      const y = H - h;
      const binMid = min + (i + 0.5) * w;
      let fill;
      if (binMid >= 3.0)  fill = `rgba(216,90,48,${0.68 + 0.32 * (i / N)})`;
      else if (binMid >= 2.5) fill = `rgba(239,159,39,0.72)`;
      else if (binMid >= 2.0) fill = `rgba(55,138,221,0.58)`;
      else                    fill = `rgba(55,138,221,${0.48 + 0.22 * (i / N)})`;
      bars += `<rect x="${x}" y="${y}" width="${barW - 1}" height="${h}" fill="${fill}"/>`;
    });

    // Selected port marker
    let marker = '';
    if (portScore !== null && portScore !== undefined) {
      const xPos = Math.round(((portScore - min) / (max - min)) * W);
      const c = scoreColor(portScore);
      marker = `
        <line x1="${xPos}" y1="0" x2="${xPos}" y2="${H}" stroke="${c}" stroke-width="2" stroke-dasharray="4,3" opacity="0.9"/>
        <circle cx="${xPos}" cy="${H - 4}" r="5" fill="${c}"/>
      `;
    }

    histWrap.innerHTML = `
      <svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        ${bars}${marker}
      </svg>
    `;

    // Update mean label
    const meanLbl = document.getElementById('hist-mean-lbl');
    if (meanLbl) meanLbl.textContent = `mean ${globalMean.toFixed(2)}`;
  }

  /* ── SHOW DETAIL PANEL ── */
  function showDetail(port) {
    selectedPort = port;
    detailEl.classList.add('visible');

    document.getElementById('dd-name').textContent = port.port_name;
    document.getElementById('dd-meta').textContent =
      `${port.country_name} · Rank #${port.pri_rank.toLocaleString()} of 3804 · rank 1 = lowest risk · Data tier ${port.data_tier}`;
    document.getElementById('dd-score').textContent = port.pri_score.toFixed(2);

    const dims = [
      { id: 'd1', score: port.d1_score, color: '#378ADD', subs: [
        { l: 'Controlling depth', v: port.ctrl_depth_final ? port.ctrl_depth_final.toFixed(1) + 'm' : '—' },
        { l: 'Vessel class coverage', v: port.vessel_class_count ?? '—' },
        { l: 'Cyclone passes', v: port.cyclone_passes !== null ? port.cyclone_passes.toFixed(0) : '—' },
        { l: 'Peak ground accel.', v: port.pga_g !== null ? port.pga_g.toFixed(3) + 'g' : '—' },
      ]},
      { id: 'd2', score: port.d2_score, color: '#EF9F27', subs: [
        { l: 'LPI score', v: port.lpi_score !== null ? port.lpi_score.toFixed(2) : '—' },
        { l: 'Dwell time', v: port.dwell_hours !== null ? port.dwell_hours.toFixed(0) + 'h' : '—' },
        { l: 'Labour regime', v: port.labour_regime ?? '—' },
      ]},
      { id: 'd3', score: port.d3_score, color: '#7F77DD', subs: [
        { l: 'Catchment share', v: port.catchment_share_pct !== null ? port.catchment_share_pct.toFixed(1) + '%' : '—' },
        { l: 'Herfindahl index', v: port.herfindahl !== null ? port.herfindahl.toFixed(3) : '—' },
        { l: 'Alt. port distance', v: port.alt_distance_km !== null ? port.alt_distance_km.toFixed(0) + 'km' : '—' },
      ]},
      { id: 'd4', score: port.d4_score, color: '#D85A30', subs: [
        { l: 'WGI pol. stability', v: port.wgi_ps !== null ? port.wgi_ps.toFixed(2) : '—' },
        { l: 'WGI gov. effectiveness', v: port.wgi_ge !== null ? port.wgi_ge.toFixed(2) : '—' },
        { l: 'Sanctions level', v: port.sanctions_level ?? '—' },
        { l: 'Dispute level', v: port.dispute_level ?? '—' },
      ]},
    ];

    dims.forEach(d => {
      const sc = d.score !== null && d.score !== undefined ? d.score : null;
      document.getElementById(`${d.id}-score`).textContent = sc !== null ? sc.toFixed(2) : '—';
      document.getElementById(`${d.id}-bar`).style.width =
        sc !== null ? `${Math.min((sc / EFF_MAX) * 100, 100).toFixed(1)}%` : '0%';
      const subsEl = document.getElementById(`${d.id}-subs`);
      subsEl.innerHTML = d.subs.map(s =>
        `<div class="pri-dc-sub-row">
          <span class="pri-dc-sub-lbl">${s.l}</span>
          <span class="pri-dc-sub-val">${s.v}</span>
        </div>`
      ).join('');
    });

    // Histogram
    document.getElementById('hist-port-lbl').textContent =
      `${port.port_name} · ${port.pri_score.toFixed(2)}`;
    drawHistogram(port.pri_score);

    // Scroll detail into view
    detailEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* ── RENDER TABLE ── */
  function renderTable() {
    tbodyEl.innerHTML = filteredPorts.map(port => {
      const sel = selectedPort && selectedPort.pri_rank === port.pri_rank ? 'selected' : '';
      return `<tr class="${sel}" data-rank="${port.pri_rank}">
        <td class="td-rank">${port.pri_rank}</td>
        <td class="td-port">${port.port_name}</td>
        <td class="td-country">${port.country_name}</td>
        <td>${scoreChip(port.pri_score, false)}</td>
        <td>${scoreChip(port.d1_score, true)}</td>
        <td>${scoreChip(port.d2_score, true)}</td>
        <td>${scoreChip(port.d3_score, true)}</td>
        <td>${scoreChip(port.d4_score, true)}</td>
      </tr>`;
    }).join('');

    // Row click → select port
    tbodyEl.querySelectorAll('tr').forEach(tr => {
      tr.addEventListener('click', () => {
        const rank = parseInt(tr.dataset.rank);
        const port = allPorts.find(p => p.pri_rank === rank);
        if (port) {
          searchEl.value = port.port_name;
          clearBtn.classList.add('visible');
          showDetail(port);
          renderTable(); // re-render to update selected row
        }
      });
    });

    // Count
    countEl.innerHTML = `<strong>${filteredPorts.length.toLocaleString()}</strong> ports`;
  }

  /* ── SORT ── */
  function applySort() {
    filteredPorts.sort((a, b) => {
      let va = a[sortCol], vb = b[sortCol];
      if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
      if (va === null || va === undefined) return 1;
      if (vb === null || vb === undefined) return -1;
      return sortAsc ? va - vb : vb - va;
    });
    renderTable();
  }

  /* ── SORT HEADERS ── */
  document.querySelectorAll('#pri-table th[data-col]').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.col;
      if (sortCol === col) { sortAsc = !sortAsc; }
      else { sortCol = col; sortAsc = (col === 'pri_rank'); }
      document.querySelectorAll('.sort-arrow').forEach(a => { a.classList.remove('active'); a.textContent = '↕'; });
      const arrow = document.getElementById(`arr-${col}`);
      if (arrow) { arrow.classList.add('active'); arrow.textContent = sortAsc ? '↑' : '↓'; }
      filteredPorts.sort((a, b) => {
        let va = a[sortCol], vb = b[sortCol];
        if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        if (va === null || va === undefined) return 1;
        if (vb === null || vb === undefined) return -1;
        return sortAsc ? va - vb : vb - va;
      });
      renderTable();
    });
  });

  /* ── SEARCH / FILTER ── */
  function filterPorts(q) {
    q = q.trim().toLowerCase();
    if (!q) return allPorts.slice();
    return allPorts.filter(p =>
      p.port_name.toLowerCase().includes(q) ||
      p.country_name.toLowerCase().includes(q) ||
      (p.iso2 && p.iso2.toLowerCase().includes(q))
    );
  }

  /* ── TYPEAHEAD ── */
  let ddFocused = -1;

  function showDropdown(q) {
    if (!q) { dropdown.classList.remove('open'); return; }
    const results = filterPorts(q).slice(0, 8);
    if (!results.length) {
      dropdown.innerHTML = `<div class="pri-dd-none">No ports found for "${q}"</div>`;
    } else {
      dropdown.innerHTML = results.map((p, i) =>
        `<div class="pri-dd-item" data-rank="${p.pri_rank}">
          <div>
            <div class="pri-dd-name">${p.port_name}</div>
            <div class="pri-dd-country">${p.country_name} · Rank #${p.pri_rank}</div>
          </div>
          <div class="pri-dd-score">${p.pri_score.toFixed(2)}</div>
        </div>`
      ).join('');
      dropdown.querySelectorAll('.pri-dd-item').forEach(item => {
        item.addEventListener('click', () => {
          const port = allPorts.find(p => p.pri_rank === parseInt(item.dataset.rank));
          if (port) selectPort(port);
        });
      });
    }
    dropdown.classList.add('open');
    ddFocused = -1;
  }

  function selectPort(port) {
    searchEl.value = port.port_name;
    dropdown.classList.remove('open');
    clearBtn.classList.add('visible');
    filteredPorts = allPorts.slice();
    applySort();
    showDetail(port);
    // Scroll selected row into view
    setTimeout(() => {
      const row = tbodyEl.querySelector(`tr[data-rank="${port.pri_rank}"]`);
      if (row) row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }

  searchEl.addEventListener('input', () => {
    const q = searchEl.value;
    clearBtn.classList.toggle('visible', q.length > 0);
    filteredPorts = filterPorts(q);
    sortCol = 'pri_rank'; sortAsc = true;
    renderTable();
    showDropdown(q);
  });

  searchEl.addEventListener('keydown', e => {
    const items = dropdown.querySelectorAll('.pri-dd-item');
    if (e.key === 'ArrowDown') {
      ddFocused = Math.min(ddFocused + 1, items.length - 1);
      items.forEach((el, i) => el.classList.toggle('focused', i === ddFocused));
      e.preventDefault();
    } else if (e.key === 'ArrowUp') {
      ddFocused = Math.max(ddFocused - 1, -1);
      items.forEach((el, i) => el.classList.toggle('focused', i === ddFocused));
      e.preventDefault();
    } else if (e.key === 'Enter' && ddFocused >= 0) {
      items[ddFocused]?.click();
    } else if (e.key === 'Escape') {
      dropdown.classList.remove('open');
    }
  });

  document.addEventListener('click', e => {
    if (!e.target.closest('.pri-search-wrap')) dropdown.classList.remove('open');
  });

  clearBtn.addEventListener('click', () => {
    searchEl.value = '';
    clearBtn.classList.remove('visible');
    filteredPorts = allPorts.slice();
    renderTable();
    dropdown.classList.remove('open');
  });

  /* ── EMAIL GATE ── */
  (function initGate() {
    const GATE_KEY = 'narrows_pri_access';
    const LOOPS_FORM_ID = 'cmpfr589400le0jwr5mkw40v6'; // ← replace with your Loops form ID
    const EXPIRY_MS = 90 * 24 * 60 * 60 * 1000; // 90 days

    const gate = document.getElementById('pri-gate');
    const form = document.getElementById('pri-gate-form');
    const btn  = document.getElementById('pri-gate-btn');
    const err  = document.getElementById('pri-gate-error');

    console.log('[PRI Gate] init — gate:', !!gate, 'form:', !!form, 'btn:', !!btn);
    if (!gate || !form || !btn) { console.error('[PRI Gate] missing elements'); return; }

    // Check if already unlocked
    let stored = null;
    try { stored = localStorage.getItem(GATE_KEY); } catch(e) { console.warn('[PRI Gate] localStorage read error:', e); }
    if (stored && (Date.now() - parseInt(stored, 10)) < EXPIRY_MS) {
      console.log('[PRI Gate] already unlocked');
      gate.classList.add('hidden');
      return;
    }

    console.log('[PRI Gate] showing gate');
    gate.classList.remove('hidden');

    function grantAccess() {
      console.log('[PRI Gate] grantAccess called');
      try { localStorage.setItem(GATE_KEY, Date.now().toString()); } catch(e) {}
      gate.classList.add('dismissing');
      setTimeout(() => gate.classList.add('hidden'), 420);
    }

    form.addEventListener('submit', function(e) {
      console.log('[PRI Gate] submit fired');
      e.preventDefault();

      const emailEl   = document.getElementById('pri-gate-email');
      const companyEl = document.getElementById('pri-gate-company');
      const email     = emailEl.value.trim();

      // Basic format check
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        emailEl.style.borderColor = '#c0392b';
        emailEl.focus();
        return;
      }
      emailEl.style.borderColor = '';

      // Grant access immediately — never block on API response
      grantAccess();

      // Send to Loops in background (fire and forget)
      if (LOOPS_FORM_ID && LOOPS_FORM_ID !== 'YOUR_LOOPS_FORM_ID') {
        const payload = new URLSearchParams({ email });
        if (companyEl && companyEl.value.trim()) {
          payload.set('company', companyEl.value.trim());
        }
        fetch(`https://app.loops.so/api/newsletter-form/${LOOPS_FORM_ID}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: payload.toString(),
        }).catch(function() {});
      }
    });
  })();

  /* ── INIT — data is already in the page, no fetch needed ── */
  (function initData() {
    const { h, r } = window.__PRI__;
    allPorts = r.map(row => {
      const obj = {};
      h.forEach((k, i) => obj[k] = row[i]);
      return obj;
    });
    globalMean = allPorts.reduce((s, p) => s + p.pri_score, 0) / allPorts.length;
    histBins = buildBins(allPorts);
    filteredPorts = allPorts.slice();
    applySort();          // applies default pri_score desc (highest risk first)
    drawHistogram(null);
  })();

})();
</script>


<script is:inline>
(function() {
  var TIER_COLOURS = {
    Moderate: '#2E86D4',
    Elevated: '#7FA8C9',
    High:     '#E8952A',
    Critical: '#F0B429',
  };
  var TIER_ORDER = ['Moderate','Elevated','High','Critical'];

  // Ensure container has explicit pixel height before Leaflet reads it
  var mapEl = document.getElementById('pri-leaflet-map');
  if (!mapEl) { console.error('[PRI Map] container not found'); return; }
  if (!window.L) { console.error('[PRI Map] Leaflet not loaded'); return; }
  console.log('[MAP] container size:', mapEl.offsetWidth, 'x', mapEl.offsetHeight, '| L defined:', typeof L);
  // Force explicit pixel dimensions so Leaflet never sees a zero-size container
  var mapH = mapEl.offsetHeight || 480;
  var mapW = mapEl.offsetWidth || window.innerWidth || 800;
  mapEl.style.width  = mapW + 'px';
  mapEl.style.height = mapH + 'px';

  var map = L.map('pri-leaflet-map', {
    center: [20, 10], zoom: 2,
    zoomControl: true, maxZoom: 14, minZoom: 2,
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
    subdomains: 'abcd', maxZoom: 19,
  }).addTo(map);

  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_only_labels/{z}/{x}/{y}{r}.png', {
    subdomains: 'abcd', maxZoom: 19, pane: 'shadowPane',
  }).addTo(map);

  console.log('[MAP] tile layers added, map size:', JSON.stringify(map.getSize()));

  var layerGroups = {};
  TIER_ORDER.forEach(function(t) { layerGroups[t] = L.layerGroup().addTo(map); });

  var activeFilters = new Set(TIER_ORDER);
  var allMarkers = [];

  function fmtDwell(v) {
    if (!v || v === 'null') return '—';
    var h = parseFloat(v);
    if (isNaN(h)) return '—';
    return h >= 24 ? (h/24).toFixed(1) + 'd' : Math.round(h) + 'h';
  }
  function fmtDepth(v) {
    if (!v || v === 'null') return '—';
    var d = parseFloat(v);
    if (isNaN(d)) return '—';
    return d.toFixed(1) + ' m';
  }

  function buildPopup(p) {
    var c = TIER_COLOURS[p.t] || '#fff';
    return '<div class="map-popup-inner">' +
      '<div class="map-popup-tier" style="color:' + c + '">' + p.t + ' Risk</div>' +
      '<div class="map-popup-name">' + p.n + '</div>' +
      '<div class="map-popup-country">' + p.c + '</div>' +
      '<hr class="map-popup-hr">' +
      '<div class="map-popup-stats">' +
        '<div><div class="map-popup-stat-lbl">PRI Score</div>' +
        '<div class="map-popup-stat-val" style="color:' + c + '">' + p.s.toFixed(2) + '</div>' +
        '<div class="map-popup-stat-unit">composite index</div></div>' +
        '<div><div class="map-popup-stat-lbl">Dwell Time</div>' +
        '<div class="map-popup-stat-val">' + fmtDwell(p.d) + '</div>' +
        '<div class="map-popup-stat-unit">avg cargo wait</div></div>' +
        '<div><div class="map-popup-stat-lbl">Depth</div>' +
        '<div class="map-popup-stat-val">' + fmtDepth(p.dp) + '</div>' +
        '<div class="map-popup-stat-unit">controlling</div></div>' +
      '</div></div>' +
      '<a class="map-popup-cta" href="#pri-search" onclick="document.getElementById('pri-search').value='' + p.n.replace(/'/g, '') + '';document.getElementById('pri-search').dispatchEvent(new Event('input'));">View full index →</a>';
  }

  function getRadius(tier, zoom) {
    var base = { Moderate: 4, Elevated: 5, High: 6, Critical: 7 };
    var r = base[tier] || 4;
    return zoom > 6 ? r + (zoom - 6) * 0.7 : r;
  }

  fetch('/pri_ports.json')
    .then(function(r) { return r.json(); })
    .then(function(ports) {
      ports.forEach(function(p) {
        var colour = TIER_COLOURS[p.t] || '#888';
        var isCrit = p.t === 'Critical';
        var marker = L.circleMarker([p.la, p.lo], {
          radius: getRadius(p.t, map.getZoom()),
          fillColor: colour,
          fillOpacity: isCrit ? 0.95 : 0.72,
          color: isCrit ? colour : 'transparent',
          weight: isCrit ? 1.5 : 0,
        });
        marker.bindPopup(buildPopup(p), { maxWidth: 220 });
        marker._tier = p.t;
        marker._portData = p;
        allMarkers.push(marker);
        layerGroups[p.t].addLayer(marker);
      });
    });

  map.on('zoomend', function() {
    var z = map.getZoom();
    allMarkers.forEach(function(m) { m.setRadius(getRadius(m._tier, z)); });
  });

  // Filters
  document.querySelectorAll('#pri-map-filters .pri-map-filter').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tier = btn.dataset.tier;
      if (activeFilters.has(tier)) {
        activeFilters.delete(tier);
        map.removeLayer(layerGroups[tier]);
        btn.classList.remove('active');
      } else {
        activeFilters.add(tier);
        layerGroups[tier].addTo(map);
        btn.classList.add('active');
      }
    });
  });
  // Force tile repaint after gate dismissal
  setTimeout(function() { map.invalidateSize(); }, 300);
})();
</script>

