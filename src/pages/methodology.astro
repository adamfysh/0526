<script>
function handleMethodRequest() {
  const input = document.getElementById('method-email') as HTMLInputElement;
  const email = input.value.trim();
  if (!email || !email.includes('@')) {
    input.style.borderColor = 'rgba(192,57,43,0.8)';
    setTimeout(() => { input.style.borderColor = ''; }, 1600);
    return;
  }
  window.location.href = `mailto:fysh@narrows.io?subject=Methodology documentation request — Narrows&body=Request from: ${email}%0A%0AOrganisation:%0ARole:%0AContext:`;
}
document.getElementById('method-btn')?.addEventListener('click', handleMethodRequest);
document.getElementById('method-email')?.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter') handleMethodRequest();
});
</script>

